# ⚡ RetrofitGPT environment variables — copy to .env and fill in

# LLM APIs
DEEPSEEK_API_KEY=your_deepseek_key          # platform.deepseek.com — 5M free tokens on signup
ANTHROPIC_API_KEY=your_anthropic_key        # Claude Sonnet for Reviewer gate only

# Observability
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com    # or http://localhost:3000 if self-hosted

# Vector Store (matches docker-compose defaults)
DATABASE_URL=postgresql://retrofit:retrofit@localhost:5432/retrofitgpt

# MCP Server
MCP_API_KEY=change_me_to_a_random_secret

# Optional: local fallback
OLLAMA_HOST=http://localhost:11434

# 🇦🇺 No keys needed for Australian data sources:
# - CDR Energy Product Reference Data (tariffs): public API
# - NGA emission factors (DCCEEW): bundled in data/factors/
# - Embeddings: local bge-small-en-v1.5 (no OpenAI key)
