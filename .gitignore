# Secrets
.env

# Copyrighted / licensed documents — NEVER commit code PDFs
data/codes/*
!data/codes/README.md

# Large simulation outputs
data/reference_buildings/cached_results/*.eso
*.eso
*.err
*.audit

# Runtime-generated data (regenerated on the box; never commit)
data/sim_output/
data/working/
# Weather files are downloaded at deploy by scripts/download_reference_data.py
data/reference_buildings/weather/

# Eval CI output (keep summary only)
evals/results/*
!evals/results/.gitkeep

# Frontend
frontend/node_modules/
frontend/.next/
frontend/.env.local

# Python
__pycache__/
*.pyc
.venv/
venv/

# OS / editor
.DS_Store
.idea/
.vscode/

# Models downloaded at runtime
.cache/

# CI workflow needs a workflow-scoped PAT to push; tracked separately
.github/workflows/ci.yml
