# Copy to .env.local (gitignored) and set to YOUR Caddy-exposed backend URL.
# This is what the browser calls — the public HTTPS URL of the RetrofitGPT
# container on the VPS, NOT the internal :8001 port.
#
#   NEXT_PUBLIC_API_BASE=https://api.yourdomain.com
#
# Must reciprocate with the backend: this frontend's origin (e.g.
# https://yourplatform.vercel.app) has to be in the backend's ALLOWED_ORIGINS,
# or the browser blocks the request (CORS).
NEXT_PUBLIC_API_BASE=http://localhost:8001
