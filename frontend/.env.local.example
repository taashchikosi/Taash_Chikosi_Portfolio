# Copy to .env.local (gitignored). Each project that has a live backend gets its
# own NEXT_PUBLIC_*_API_BASE. The browser calls these directly, so they must be
# the PUBLIC https URL, and the frontend's origin must be in that backend's
# ALLOWED_ORIGINS (CORS) or the browser blocks the request.

# RetrofitGPT backend (VPS, behind Caddy TLS):
NEXT_PUBLIC_API_BASE=https://204-168-226-100.sslip.io

# AuditAgent backend (VPS port 8002, behind Caddy TLS). Set this in Vercel + here
# once the container is deployed; until then the /auditagent status dot shows "offline".
# The backend must include this site's origin in AUDITAGENT_ALLOWED_ORIGINS (CORS).
NEXT_PUBLIC_AUDITAGENT_API_BASE=http://localhost:8002

# Onboarding Auto-Builder backend (VPS port 8008, behind Caddy TLS). Live.
# The backend includes this site's origin in OAB_CORS_ORIGINS (CORS matched pair).
NEXT_PUBLIC_ONBOARDING_BUILDER_API_BASE=https://onboarding-builder.204-168-226-100.sslip.io

# doc-intelligence backend (VPS port 8003, behind Caddy TLS). Live. The /doc-intelligence/demo
# status dot reads /health from this origin; the backend's CORS_ORIGINS must include this
# site's origin (currently "*" for the public read-only demo).
NEXT_PUBLIC_DOCINTEL_API_BASE=https://doc-intelligence.204-168-226-100.sslip.io
